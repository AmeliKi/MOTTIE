# MOTTIE configuration template.
# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored and must never be committed.

# --- Azure IoT Hub ---
# Device-scoped connection string from the IoT Hub portal:
#   "HostName=<hub>.azure-devices.net;DeviceId=<device-id>;SharedAccessKey=<key>"
IOT_HUB_CONNECTION_STRING=

# --- Azure Data Lake / Blob Storage ---
STORAGE_ACCOUNT_NAME=
STORAGE_ACCOUNT_KEY=
STORAGE_ACCOUNT_CONTAINER_NAME=mothcam
STORAGE_ACCOUNT_DIRECTORY_NAME=upload

# --- Camera / image defaults ---
IMAGE_WIDTH=2312
IMAGE_HEIGHT=1736
IMAGE_FORMAT=RGB888
FILENAME_PREFIX=moth

# --- Behaviour flags ---
# When false, IoT-Hub-bound modules and ML inference are skipped so the
# device can run in pure local mode (camera + LEDs only).
ENABLE_IOT=true
ENABLE_INFERENCE=false
